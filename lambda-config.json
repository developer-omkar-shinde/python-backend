{
  "lambdas": {
    "onboarding": {
      "function_name": "dev-onboarding",
      "service_path": "services/onboarding_service/onboarding",
      "handler": "lambda_function.lambda_handler",
      "description": "Onboarding service Lambda - processes SQS events from SNS",
      "environment": {
        "STAGE": "dev",
        "LOG_LEVEL": "INFO"
      }
    },
    "email": {
      "function_name": "dev-email-service",
      "service_path": "services/email_service",
      "handler": "lambda_function.lambda_handler",
      "description": "Email service Lambda - sends emails from SNS/SQS events",
      "environment": {
        "STAGE": "dev",
        "LOG_LEVEL": "INFO"
      }
    }
  },
  "build_config": {
    "python_version": "3.11",
    "exclude_patterns": [
      "*.pyc",
      "__pycache__",
      "*.egg-info",
      ".git*",
      "tests/",
      ".pytest_cache"
    ]
  }
}
